{
  "name": "@theojs/lumen",
  "version": "6.4.7",
  "description": "专为 VitePress 打造的主题美化与 Vue 扩展组件库",
  "keywords": [
    "css",
    "vue",
    "vite",
    "typescript",
    "vitepress",
    "vitepress-plugin",
    "vitepress-theme",
    "vitepress-ui",
    "comment",
    "waline",
    "iconify",
    "iconify-icon",
    "tools",
    "theojs",
    "lumen",
    "vitepress-enhance"
  ],
  "homepage": "https://lumen.theojs.cn/",
  "bugs": {
    "url": "https://github.com/s-theo/lumen/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/s-theo/lumen.git",
    "directory": "src"
  },
  "license": "MIT",
  "author": "Theo",
  "type": "module",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./types/index.ts"
    },
    "./style": {
      "types": "./types/style.d.ts",
      "import": "./style/all.css",
      "default": "./style/all.css"
    },
    "./icon": {
      "types": "./types/style.d.ts",
      "import": "./style/icon.css",
      "default": "./style/icon.css"
    },
    "./button": {
      "types": "./types/style.d.ts",
      "import": "./style/button.css",
      "default": "./style/button.css"
    },
    "./colors": {
      "types": "./types/style.d.ts",
      "import": "./style/colors.css",
      "default": "./style/colors.css"
    },
    "./doc": {
      "types": "./types/style.d.ts",
      "import": "./style/doc.css",
      "default": "./style/doc.css"
    },
    "./doc-blocks": {
      "types": "./types/style.d.ts",
      "import": "./style/doc-blocks.css",
      "default": "./style/doc-blocks.css"
    },
    "./home": {
      "types": "./types/style.d.ts",
      "import": "./style/home.css",
      "default": "./style/home.css"
    },
    "./pic": {
      "types": "./types/style.d.ts",
      "import": "./style/picture.css",
      "default": "./style/picture.css"
    },
    "./badge": {
      "types": "./types/style.d.ts",
      "import": "./style/badge.css",
      "default": "./style/badge.css"
    },
    "./components-var": {
      "types": "./types/style.d.ts",
      "import": "./style/components-var.css",
      "default": "./style/components-var.css"
    },
    "./package.json": "./package.json"
  },
  "main": "./types/index.ts",
  "module": "./types/index.ts",
  "types": "./types/index.d.ts",
  "style": "./style/all.css",
  "sideEffects": [
    "./types/index.ts",
    "**/*.css"
  ],
  "files": [
    "style/",
    "types/",
    "components/",
    "composables/",
    "tsconfig.json",
    "readme.md",
    "License"
  ],
  "scripts": {
    "release": "bumpp && pnpm publish --registry=https://registry.npmjs.org"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.1",
    "@waline/client": "^3.15.2",
    "iconify-icon": "^3.0.2",
    "typescript": "^7.0.2"
  },
  "peerDependencies": {
    "vitepress": "^1.6.4 || >=2.0.0-alpha.18 <3.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "bumpp": "^11.1.0",
    "vitepress": "catalog:",
    "vue": "catalog:"
  },
  "packageManager": "pnpm@11.10.0"
}
