{
  "name": "lumen",
  "private": true,
  "homepage": "https://lumen.theojs.cn/",
  "repository": "s-theo/lumen",
  "license": "MIT",
  "author": "Theo",
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "scripts": {
    "build": "pnpm -F=docs build",
    "change": "cd src && pnpm dlx changelogithub --dry",
    "clean": "pnpm clean:pnpm && pnpm clean:nm && pnpm clean:vp",
    "clean:nm": "rm -rf */node_modules node_modules pnpm-lock.yaml",
    "clean:pnpm": "rm -rf pnpm store prune && pnpm cache delete '*'",
    "clean:vp": "rm -rf docs/.vitepress/{cache,dist}",
    "dev": "pnpm -F=docs dev",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "generate:dts": "node src/scripts/generate-dts.cjs",
    "iall": "pnpm -r install",
    "preview": "pnpm -F=docs preview",
    "release": "cd src && pnpm release",
    "upall": "pnpm -r update --latest"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "lint-staged": "^17.0.8",
    "simple-git-hooks": "^2.13.1"
  },
  "packageManager": "pnpm@11.10.0"
}
