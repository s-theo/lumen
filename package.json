{
  "name": "lumen",
  "private": true,
  "homepage": "https://lumen.theojs.cn/",
  "repository": "s-theo/lumen",
  "license": "MIT",
  "author": "Theo",
  "scripts": {
    "build": "pnpm -F=docs build",
    "change": "cd src && pnpm dlx changelogithub --dry",
    "clean": "pnpm clean:pnpm && pnpm clean:nm && pnpm clean:vp",
    "clean:nm": "rm -rf */node_modules node_modules pnpm-lock.yaml",
    "clean:pnpm": "rm -rf pnpm store prune && pnpm cache delete '*'",
    "clean:vp": "rm -rf docs/.vitepress/{cache,dist}",
    "commitlint": "commitlint --edit",
    "cz": "git-cz",
    "dev": "pnpm -F=docs dev",
    "biome:check": "pnpm biome check .",
    "biome:fix": "pnpm biome check --write .",
    "iall": "pnpm -r install",
    "preview": "pnpm -F=docs preview",
    "release": "cd src && pnpm release",
    "upall": "pnpm -r update --latest"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched"
  },
  "config": {
    "commitizen": {
      "path": "cz-vinyl"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "commitizen": "^4.3.1",
    "cz-vinyl": "^2.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1"
  },
  "packageManager": "pnpm@10.32.1"
}
